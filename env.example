# Copy to .env.local and fill in real values. NEVER commit real secrets.
# (.gitignore excludes .env*)

# ── Database: PostgreSQL on Neon (V2 — Prisma) ──
# Pooled connection for the app at runtime:
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
# Direct (unpooled) connection for `prisma migrate` (non-pooler host):
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# ── Auth (NextAuth) ──
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Legacy (V1 — being retired) ──
# MONGODB_URI=
