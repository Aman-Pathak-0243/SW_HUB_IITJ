# Copy to .env.local and fill in real values. NEVER commit real secrets.
# (.gitignore excludes .env*)

# ── Database: PostgreSQL on Neon (V2 — Prisma) ──
# Pooled connection for the app at runtime. For Prisma + Neon's PgBouncer pooler,
# append pgbouncer=true (disables prepared statements; required for correctness).
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&channel_binding=require&pgbouncer=true"
# Direct (unpooled) connection for `prisma migrate` (non-pooler host — drop the
# "-pooler" suffix). Required: Prisma migrations do not work through the pooler.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# ── Auth (NextAuth v4) ──
NEXTAUTH_SECRET=          # generate: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Seed bootstrap (used by `npm run db:seed`) ──
# The Developer super-user and the Super-Admin emails that replace the V1
# hardcoded allowlist. BOOTSTRAP_DEVELOPER_PASSWORD is optional — if unset the
# developer account is OAuth-only (sign in with Google using that email).
BOOTSTRAP_DEVELOPER_EMAIL=developer@iitjammu.ac.in
# BOOTSTRAP_DEVELOPER_PASSWORD=
BOOTSTRAP_ADMIN_EMAILS=

# ── Legacy (V1 — being retired) ──
# MONGODB_URI=
