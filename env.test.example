# Local-Postgres TEST environment (Session 13). Copy to `.env.test` (git-ignored via
# `.env*`) to run the live `*.db.test.mjs` suites against the Docker Postgres in
# docker-compose.yml — fast, offline, and with all Postgres guards intact. These are
# THROWAWAY local credentials for a THROWAWAY local DB; never point these at a real host.
#
#   cp env.test.example .env.test
#   npm run db:local:up && npm run db:local:setup && npm run test:db

# Docker Postgres (docker-compose.yml). For a LOCAL server DATABASE_URL == DIRECT_URL
# (no pgbouncer/pooler, unlike Neon), so no `?pgbouncer=true` is needed.
DATABASE_URL="postgresql://iitj:iitj@localhost:5432/iitj_test?schema=public"
DIRECT_URL="postgresql://iitj:iitj@localhost:5432/iitj_test?schema=public"

# NextAuth (test-only — not a production secret).
NEXTAUTH_SECRET="local-test-secret-change-me"
NEXTAUTH_URL="http://localhost:3000"

# Bootstrap accounts the seed creates. Setting the developer password here lets you sign
# in locally as the developer (the seed only sets it when this var is present).
BOOTSTRAP_DEVELOPER_EMAIL="developer@iitjammu.ac.in"
BOOTSTRAP_DEVELOPER_PASSWORD="localdev123"
BOOTSTRAP_ADMIN_EMAILS=""
