// ──────────────────────────────────────────────────────────────────────────
// MEMBER PLATFORM — Session 11 / M0 (plugin control plane + request queue)
// ──────────────────────────────────────────────────────────────────────────

// Developer-controlled feature flags ("plugins"). The whole Session 11+ member
// platform is gated behind the `member_platform` flag: when a DEVELOPER turns it
// on, the member-platform features (email+password-only auth, member pages,
// account/reset request flows, forced first-login password change) activate;
// when off, the portal behaves exactly as Sessions 1–10. Toggling is
// developer-only + audited (lib/platform/flags.mjs). The flag catalog is seeded
// from PLUGIN_DEFS; re-seeding never resets an operator's chosen `enabled`.
model FeatureFlag {
  key         String   @id // 'member_platform' (stable slug)
  name        String
  description String?
  enabled     Boolean  @default(false)
  category    String   @default("plugin") // plugin | setting
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz
  updatedById String?  @map("updated_by") @db.Uuid

  updatedBy User? @relation("FeatureFlagUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([category])
  @@map("feature_flag")
}

// Centralized notification / request queue. M0 introduces it for the
// admin-mediated account lifecycle (account-creation requests + password-reset
// requests surfaced on the admin & developer Password Management tabs, with
// assignment tracking). M7 extends it (more types/labels, threshold alerts,
// keyset pagination) — same table, no parallel pipeline. `referenceId` is a
// human, monotonic, unique handle (e.g. AR-00001 / PR-00001) minted from the
// raw-SQL `notification_ref_seq` sequence by the service; `status` is guarded by
// a CHECK (open|assigned|resolved|dismissed).
model Notification {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referenceId      String    @unique @map("reference_id")
  type             String // account_request | password_reset | threshold_alert | system (M7)
  // M7 (DL-069): a free-text LABEL for grouping/filtering the centralized queue
  // (e.g. "accounts", "security", "storage"). Distinct from `type` (the workflow
  // kind); nullable so existing rows are unaffected.
  label            String?
  status           String    @default("open")
  title            String
  body             String?
  subjectEmail     String?   @map("subject_email") @db.Citext
  entityType       String?   @map("entity_type")
  entityId         String?   @map("entity_id") @db.Uuid // polymorphic — intentionally not an FK
  data             Json?     @db.JsonB
  assignedToUserId String?   @map("assigned_to_user_id") @db.Uuid
  assignedAt       DateTime? @map("assigned_at") @db.Timestamptz
  resolvedByUserId String?   @map("resolved_by_user_id") @db.Uuid
  resolvedAt       DateTime? @map("resolved_at") @db.Timestamptz
  resolutionNote   String?   @map("resolution_note")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  assignedTo User? @relation("NotificationAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  resolvedBy User? @relation("NotificationResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@index([status, createdAt(sort: Desc)])
  @@index([type, status])
  @@index([subjectEmail])
  @@index([assignedToUserId])
  @@index([label])
  @@map("notification")
}

// ──────────────────────────────────────────────────────────────────────────
// MEMBER PLATFORM — Session 11 / M2 (RBAC: per-email permission overrides)
// ──────────────────────────────────────────────────────────────────────────

// Per-user (per-email) permission override (M2, DL-062). RBAC "categories" are
// roles (data) whose default `role_permission` map gives a member their baseline;
// an override then GRANTS or DENIES a single catalog permission to one specific
// account, optionally scoped to an org-unit lineage and/or academic year. This is
// what REVISES DL-026 #8's "no-deny" rule: `resolveEffectivePermissions` now
// applies the additive role union FIRST, then these overrides — and DENY WINS. A
// developer / `grants_all` role still short-circuits BEFORE overrides (the
// unrestricted bypass is never restricted by an override). `mode` is guarded by a
// CHECK; at most ONE override exists per (user, permission, scope) — a
// NULLS-NOT-DISTINCT unique closes the null-scope hole, mirroring
// `role_assignment_unique_active_grant_uq`. Email is the unique identifier the
// admin search keys on, so an override is "per email" via the user FK.
model UserPermissionOverride {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  permissionId      String   @map("permission_id") @db.Uuid
  mode              String // 'grant' | 'deny' (CHECK in raw SQL) — deny wins (DL-062)
  orgUnitLineageKey String?  @map("org_unit_lineage_key") @db.Uuid
  academicYearId    String?  @map("academic_year_id") @db.Uuid
  reason            String?
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdById       String?  @map("created_by") @db.Uuid

  user           User            @relation("UserPermissionOverrideUser", fields: [userId], references: [id], onDelete: Cascade)
  permission     Permission      @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  orgUnitLineage OrgUnitLineage? @relation(fields: [orgUnitLineageKey], references: [lineageKey], onDelete: Restrict)
  academicYear   AcademicYear?   @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  createdBy      User?           @relation("UserPermissionOverrideCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([permissionId])
  @@map("user_permission_override")
}

// ──────────────────────────────────────────────────────────────────────────
// MEMBER PLATFORM — Session 11 / M7 (feedback) + M8 (usage, storage, mail)
// ──────────────────────────────────────────────────────────────────────────

// Feedback / support tickets (M7, DL-070) — a STANDALONE table (the DL-038 rule:
// not CMS content). A public form creates a ticket with a human, DB-unique
// `reference_id` (FB-NNNNN from a raw-SQL sequence) so a user can reference a bug
// against any component/service id (`component`); stakeholders triage → assign →
// resolve through a `status` workflow (CHECK-guarded). Assignment/status changes
// are audited (cross-stakeholder); the public create is itself the durable record.
model Feedback {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referenceId      String    @unique @map("reference_id")
  category         String // bug | issue | query | suggestion (CHECK)
  status           String    @default("open") // open | triaged | in_progress | resolved | dismissed (CHECK)
  subject          String
  body             String
  component        String? // the component/service id the report is against
  submitterEmail   String?   @map("submitter_email") @db.Citext
  submitterUserId  String?   @map("submitter_user_id") @db.Uuid
  assignedToUserId String?   @map("assigned_to_user_id") @db.Uuid
  assignedAt       DateTime? @map("assigned_at") @db.Timestamptz
  resolvedByUserId String?   @map("resolved_by_user_id") @db.Uuid
  resolvedAt       DateTime? @map("resolved_at") @db.Timestamptz
  resolutionNote   String?   @map("resolution_note")
  data             Json?     @db.JsonB
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  submitter  User? @relation("FeedbackSubmitter", fields: [submitterUserId], references: [id], onDelete: SetNull)
  assignedTo User? @relation("FeedbackAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  resolvedBy User? @relation("FeedbackResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)

  @@index([status, createdAt(sort: Desc)])
  @@index([category, status])
  @@index([submitterEmail])
  @@index([assignedToUserId])
  @@map("feedback")
}

// Hidden usage analytics (M8, DL-071) — which sections are visited most. BIGSERIAL
// PK (high-volume, monotonic — keyset paging like audit_log, DL-018). `userId` is
// nullable + SET NULL (an anonymous/public visit has none; a deleted user's visits
// keep their aggregate). Minimal by design: path + an optional section label + an
// optional user + when. Never audited (in AUTO_AUDIT_SKIP).
model PageVisit {
  id        BigInt   @id @default(autoincrement())
  path      String
  section   String?
  userId    String?  @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation("PageVisitUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([section, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("page_visit")
}

// Per-table size threshold (M8, DL-072). A developer sets a byte threshold per
// table; the storage report flags tables whose live size exceeds it (NON-blocking —
// the site keeps working) and posts a dashboard message. `tableName` is the unique
// key. Set/cleared by `storage.manage` (developer-only), audited.
model TableThreshold {
  tableName      String   @id @map("table_name")
  thresholdBytes BigInt   @map("threshold_bytes")
  note           String?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz
  updatedById    String?  @map("updated_by") @db.Uuid

  updatedBy User? @relation("TableThresholdUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@map("table_threshold")
}

// Authorized mail senders (M8, DL-073). nodemailer bulk sends are restricted to
// this admin/dev-maintained allowlist (`mail.manage`). Email is the unique key;
// `active` lets a sender be disabled without deletion. Maintained = audited.
model AuthorizedSender {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email       String   @unique @db.Citext
  name        String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdById String?  @map("created_by") @db.Uuid

  createdBy User? @relation("AuthorizedSenderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([active])
  @@map("authorized_sender")
}
