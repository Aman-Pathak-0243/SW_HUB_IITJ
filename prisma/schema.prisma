// IIT Jammu Student Affairs Portal V2 — Prisma schema
// AUTHORITATIVE SOURCE: docs/SCHEMA_DESIGN.md (33 tables, 14 Prisma enums).
// Models map 1:1 to snake_case tables via @@map; fields map via @map.
// Raw-SQL objects Prisma cannot express (partial/expression/NULLS-NOT-DISTINCT
// uniques, triggers, GIN/BRIN, bigint identity, CHECKs, citext extension) live
// in the init migration's hand-written tail — see prisma/migrations and
// docs/SCHEMA_DESIGN.md "Prisma/Postgres/Neon notes". NEVER `prisma db pull`
// (it would drop those objects from the schema's view).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (PgBouncer) — used by the app at runtime
  directUrl = env("DIRECT_URL") // unpooled — used by prisma migrate / introspection
}

// ──────────────────────────────────────────────────────────────────────────
// ENUMS (14) — small, fixed, code-coupled vocabularies. Extensible / FK-
// referenced sets (org_unit_type, role, permission, position, content_type)
// are LOOKUP TABLES, not enums (see DECISION_LOG DL-014).
// ──────────────────────────────────────────────────────────────────────────

enum AcademicYearStatus {
  planning
  active
  locked

  @@map("academic_year_status")
}

// Member-platform M1 (Session 11): three access modes (DL-065). active = full;
// inactive = can log in + browse + see own achievements but CANNOT participate in
// events; revoked = cannot log in (rejected at authorize/signIn), public site only.
// Forward-migrated from the legacy active/suspended/invited/disabled set
// (suspended+invited → inactive, disabled → revoked) via a CREATE-style enum swap
// + data backfill (never an init rewrite — DL-027).
enum UserStatus {
  active
  inactive
  revoked

  @@map("user_status")
}

enum EntityStatus {
  active
  archived

  @@map("entity_status")
}

enum ContentStatus {
  draft
  review
  published
  archived

  @@map("content_status")
}

enum RevisionStatus {
  draft
  review
  published
  superseded

  @@map("revision_status")
}

enum PersonType {
  faculty
  student
  staff
  external

  @@map("person_type")
}

enum MealType {
  breakfast
  lunch
  snacks
  dinner

  @@map("meal_type")
}

enum AudienceType {
  public
  students
  faculty
  staff
  internal

  @@map("audience_type")
}

enum ResourceKind {
  pdf
  link
  drive
  file

  @@map("resource_kind")
}

enum StorageProvider {
  cloudinary
  local
  external

  @@map("storage_provider")
}

enum MediaKind {
  image
  pdf
  svg
  gif

  @@map("media_kind")
}

enum MediaRole {
  gallery
  hero
  hero_primary
  attachment

  @@map("media_role")
}

enum AuditAction {
  create
  update
  delete
  publish
  unpublish
  archive
  restore
  login
  transition
  grant_role
  revoke_role

  @@map("audit_action")
}

enum TransitionStatus {
  pending
  running
  completed
  failed

  @@map("transition_status")
}

// ──────────────────────────────────────────────────────────────────────────
// IDENTITY & AUTH (NextAuth v4 PrismaAdapter canonical shape; JWT sessions —
// no Session model). Prisma models are named User/Account/VerificationToken so
// the default PrismaAdapter resolves prisma.user / prisma.account /
// prisma.verificationToken; the TABLES stay app_user/auth_account/
// verification_token via @@map (see DECISION_LOG DL-017).
// ──────────────────────────────────────────────────────────────────────────

model User {
  id                 String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email              String     @unique @db.Citext
  emailVerified      DateTime?  @map("email_verified_at") @db.Timestamptz
  passwordHash       String?    @map("password_hash") // argon2id; NULL when OAuth-only
  name               String     @map("display_name") // adapter User.name
  image              String? // adapter User.image (OAuth avatar URL); curated avatar is `avatar`
  avatarMediaId      String?    @map("avatar_media_id") @db.Uuid
  isDeveloper        Boolean    @default(false) @map("is_developer")
  status             UserStatus @default(active)
  // Member-platform M0 (Session 11): admin-provisioned accounts get an initial
  // password and must_change_password=true → forced change on first login. Cleared
  // when the user changes it. password_set_at records the last credential change.
  mustChangePassword Boolean    @default(false) @map("must_change_password")
  passwordSetAt      DateTime?  @map("password_set_at") @db.Timestamptz
  // M1 (DL-067): per-account "allow normal (member) view" toggle. When false the
  // authenticated member surface is withheld even though the account can still log
  // in (e.g. an account onboarded but not yet cleared for the member experience);
  // admin/dev-settable + audited. Defaults true so existing accounts are unaffected.
  allowNormalView    Boolean    @default(true) @map("allow_normal_view")
  lastLoginAt        DateTime?  @map("last_login_at") @db.Timestamptz
  createdAt          DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  avatar   MediaAsset? @relation("UserAvatar", fields: [avatarMediaId], references: [id], onDelete: SetNull)
  accounts Account[]

  // Back-relations — every inbound FK to app_user (enumerated so prisma validate passes)
  academicYearsCreated   AcademicYear[]    @relation("AcademicYearCreatedBy")
  academicYearsUpdated   AcademicYear[]    @relation("AcademicYearUpdatedBy")
  rolesCreated           Role[]            @relation("RoleCreatedBy")
  rolesUpdated           Role[]            @relation("RoleUpdatedBy")
  orgUnitLineagesCreated OrgUnitLineage[]  @relation("OrgUnitLineageCreatedBy")
  roleAssignments        RoleAssignment[]  @relation("RoleAssignmentUser")
  roleAssignmentsGranted RoleAssignment[]  @relation("RoleAssignmentGrantedBy")
  roleAssignmentsRevoked RoleAssignment[]  @relation("RoleAssignmentRevokedBy")
  orgUnitsCreated        OrgUnit[]         @relation("OrgUnitCreatedBy")
  orgUnitsUpdated        OrgUnit[]         @relation("OrgUnitUpdatedBy")
  personsCreated         Person[]          @relation("PersonCreatedBy")
  personsUpdated         Person[]          @relation("PersonUpdatedBy")
  personLinks            Person[]          @relation("PersonAppUser")
  appointmentsCreated    Appointment[]     @relation("AppointmentCreatedBy")
  appointmentsUpdated    Appointment[]     @relation("AppointmentUpdatedBy")
  contentItemsCreated    ContentItem[]     @relation("ContentItemCreatedBy")
  contentItemsUpdated    ContentItem[]     @relation("ContentItemUpdatedBy")
  contentItemsPublished  ContentItem[]     @relation("ContentItemPublishedBy")
  contentRevisions       ContentRevision[] @relation("ContentRevisionCreatedBy")
  mediaUploaded          MediaAsset[]      @relation("MediaUploadedBy")
  auditLogs              AuditLog[]        @relation("AuditLogActor")
  transitionRunsRun      TransitionRun[]   @relation("TransitionRunRunBy")
  backupRecordsCreated   BackupRecord[]    @relation("BackupRecordCreatedBy")
  featureFlagsUpdated    FeatureFlag[]     @relation("FeatureFlagUpdatedBy")
  notificationsAssigned  Notification[]    @relation("NotificationAssignedTo")
  notificationsResolved  Notification[]    @relation("NotificationResolvedBy")
  permissionOverrides    UserPermissionOverride[] @relation("UserPermissionOverrideUser")
  permissionOverridesSet UserPermissionOverride[] @relation("UserPermissionOverrideCreatedBy")
  feedbackSubmitted      Feedback[]        @relation("FeedbackSubmitter")
  feedbackAssigned       Feedback[]        @relation("FeedbackAssignedTo")
  feedbackResolved       Feedback[]        @relation("FeedbackResolvedBy")
  pageVisits             PageVisit[]       @relation("PageVisitUser")
  tableThresholdsUpdated TableThreshold[]  @relation("TableThresholdUpdatedBy")
  authorizedSendersCreated AuthorizedSender[] @relation("AuthorizedSenderCreatedBy")

  @@index([status])
  @@map("app_user")
}

model Account {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String   @map("provider_account_id")
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("auth_account")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime @db.Timestamptz

  @@unique([identifier, token])
  @@map("verification_token")
}

// ──────────────────────────────────────────────────────────────────────────
// TEMPORAL SPINE
// ──────────────────────────────────────────────────────────────────────────

model AcademicYear {
  id                     String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  label                  String             @unique // 'YYYY-YY' (CHECK in raw SQL)
  startDate              DateTime           @map("start_date") @db.Date
  endDate                DateTime           @map("end_date") @db.Date
  status                 AcademicYearStatus @default(planning)
  isCurrent              Boolean            @default(false) @map("is_current")
  transitionedFromYearId String?            @map("transitioned_from_year_id") @db.Uuid
  createdAt              DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime           @updatedAt @map("updated_at") @db.Timestamptz
  createdById            String?            @map("created_by") @db.Uuid
  updatedById            String?            @map("updated_by") @db.Uuid

  transitionedFrom AcademicYear?  @relation("YearTransition", fields: [transitionedFromYearId], references: [id], onDelete: SetNull)
  transitionedTo   AcademicYear[] @relation("YearTransition")
  createdBy        User?          @relation("AcademicYearCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy        User?          @relation("AcademicYearUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  orgUnits             OrgUnit[]
  appointments         Appointment[]    @relation("AppointmentYear")
  contentItems         ContentItem[]
  roleAssignments      RoleAssignment[]
  permissionOverrides  UserPermissionOverride[]
  auditLogs            AuditLog[]
  lineagesFirstSeen    OrgUnitLineage[] @relation("LineageFirstSeenYear")
  transitionRunsSource TransitionRun[]  @relation("TransitionSourceYear")
  transitionRunsTarget TransitionRun[]  @relation("TransitionTargetYear")

  @@index([status])
  @@index([transitionedFromYearId])
  @@map("academic_year")
}

// ──────────────────────────────────────────────────────────────────────────
// RBAC
// ──────────────────────────────────────────────────────────────────────────

model Role {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String       @unique
  name        String
  description String?
  isSystem    Boolean      @default(false) @map("is_system")
  grantsAll   Boolean      @default(false) @map("grants_all")
  status      EntityStatus @default(active)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  createdById String?      @map("created_by") @db.Uuid
  updatedById String?      @map("updated_by") @db.Uuid

  createdBy       User?            @relation("RoleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy       User?            @relation("RoleUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  rolePermissions RolePermission[]
  roleAssignments RoleAssignment[]

  @@index([status])
  @@map("role")
}

model Permission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String   @unique
  label       String
  description String?
  module      String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  rolePermissions     RolePermission[]
  permissionOverrides UserPermissionOverride[]

  @@index([module])
  @@map("permission")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permission")
}

model OrgUnitLineage {
  lineageKey      String   @id @default(dbgenerated("gen_random_uuid()")) @map("lineage_key") @db.Uuid
  canonicalName   String?  @map("canonical_name")
  firstSeenYearId String?  @map("first_seen_year_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  createdById     String?  @map("created_by") @db.Uuid

  firstSeenYear AcademicYear? @relation("LineageFirstSeenYear", fields: [firstSeenYearId], references: [id], onDelete: SetNull)
  createdBy     User?         @relation("OrgUnitLineageCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  orgUnits            OrgUnit[]
  roleAssignments     RoleAssignment[]
  permissionOverrides UserPermissionOverride[]

  @@index([firstSeenYearId])
  @@map("org_unit_lineage")
}

model RoleAssignment {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  roleId            String    @map("role_id") @db.Uuid
  orgUnitLineageKey String?   @map("org_unit_lineage_key") @db.Uuid
  academicYearId    String?   @map("academic_year_id") @db.Uuid
  grantedAt         DateTime  @default(now()) @map("granted_at") @db.Timestamptz
  grantedById       String?   @map("granted_by") @db.Uuid
  revokedAt         DateTime? @map("revoked_at") @db.Timestamptz
  revokedById       String?   @map("revoked_by") @db.Uuid

  user           User            @relation("RoleAssignmentUser", fields: [userId], references: [id], onDelete: Cascade)
  role           Role            @relation(fields: [roleId], references: [id], onDelete: Restrict)
  orgUnitLineage OrgUnitLineage? @relation(fields: [orgUnitLineageKey], references: [lineageKey], onDelete: Restrict)
  academicYear   AcademicYear?   @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  grantedBy      User?           @relation("RoleAssignmentGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)
  revokedBy      User?           @relation("RoleAssignmentRevokedBy", fields: [revokedById], references: [id], onDelete: SetNull)

  @@index([orgUnitLineageKey])
  @@index([academicYearId])
  @@index([roleId])
  // The hottest RBAC query (lib/rbac/authorize.mjs) filters by userId + revokedAt
  // on every permission resolution; userId had NO index (Postgres does not index FK
  // columns automatically), forcing a seq scan. This composite serves it directly.
  @@index([userId, revokedAt])
  @@map("role_assignment")
}

// ──────────────────────────────────────────────────────────────────────────
// ORGANIZATION MODEL
// ──────────────────────────────────────────────────────────────────────────

model OrgUnitType {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String       @unique
  name        String
  description String?
  iconMediaId String?      @map("icon_media_id") @db.Uuid
  sortOrder   Int          @default(0) @map("sort_order")
  isSystem    Boolean      @default(false) @map("is_system")
  status      EntityStatus @default(active)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  icon MediaAsset? @relation("OrgUnitTypeIcon", fields: [iconMediaId], references: [id], onDelete: SetNull)

  orgUnits        OrgUnit[]
  positions       Position[]
  appointments    Appointment[]
  allowedChildren OrgUnitTypeAllowedChild[] @relation("AllowedChildParent")
  allowedParents  OrgUnitTypeAllowedChild[] @relation("AllowedChildChild")

  @@index([status])
  @@map("org_unit_type")
}

model OrgUnitTypeAllowedChild {
  parentTypeId String @map("parent_type_id") @db.Uuid
  childTypeId  String @map("child_type_id") @db.Uuid

  parentType OrgUnitType @relation("AllowedChildParent", fields: [parentTypeId], references: [id], onDelete: Cascade)
  childType  OrgUnitType @relation("AllowedChildChild", fields: [childTypeId], references: [id], onDelete: Restrict)

  @@id([parentTypeId, childTypeId])
  @@index([childTypeId])
  @@map("org_unit_type_allowed_child")
}

model OrgUnit {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  academicYearId String        @map("academic_year_id") @db.Uuid
  orgUnitTypeId  String        @map("org_unit_type_id") @db.Uuid
  parentId       String?       @map("parent_id") @db.Uuid
  lineageKey     String        @map("lineage_key") @db.Uuid
  slug           String
  name           String
  sortOrder      Int           @default(0) @map("sort_order")
  status         ContentStatus @default(draft)
  archivedAt     DateTime?     @map("archived_at") @db.Timestamptz
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  createdById    String?       @map("created_by") @db.Uuid
  updatedById    String?       @map("updated_by") @db.Uuid

  academicYear AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  orgUnitType  OrgUnitType    @relation(fields: [orgUnitTypeId], references: [id], onDelete: Restrict)
  parent       OrgUnit?       @relation("OrgUnitParent", fields: [parentId], references: [id], onDelete: Restrict)
  children     OrgUnit[]      @relation("OrgUnitParent")
  lineage      OrgUnitLineage @relation(fields: [lineageKey], references: [lineageKey], onDelete: Restrict)
  createdBy    User?          @relation("OrgUnitCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?          @relation("OrgUnitUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  appointments Appointment[] @relation("AppointmentOrgUnit")
  contentItems ContentItem[]

  @@unique([id, academicYearId]) // composite target for appointment's year-agreement FK
  @@unique([academicYearId, slug])
  @@unique([academicYearId, lineageKey])
  @@index([academicYearId, orgUnitTypeId])
  @@index([parentId])
  @@index([lineageKey])
  @@map("org_unit")
}

model Person {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fullName     String     @map("full_name")
  personType   PersonType @map("person_type")
  email        String?    @db.Citext
  phone        String?
  profileUrl   String?    @map("profile_url")
  photoMediaId String?    @map("photo_media_id") @db.Uuid
  appUserId    String?    @map("app_user_id") @db.Uuid
  archivedAt   DateTime?  @map("archived_at") @db.Timestamptz
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  createdById  String?    @map("created_by") @db.Uuid
  updatedById  String?    @map("updated_by") @db.Uuid

  photo     MediaAsset? @relation("PersonPhoto", fields: [photoMediaId], references: [id], onDelete: SetNull)
  appUser   User?       @relation("PersonAppUser", fields: [appUserId], references: [id], onDelete: SetNull)
  createdBy User?       @relation("PersonCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?       @relation("PersonUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  appointments Appointment[]

  @@index([personType])
  @@index([appUserId])
  @@map("person")
}

model Position {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key             String       @unique
  name            String
  appliesToTypeId String?      @map("applies_to_type_id") @db.Uuid
  holderKind      PersonType?  @map("holder_kind")
  maxHolders      Int?         @map("max_holders")
  rank            Int          @default(0)
  isLead          Boolean      @default(false) @map("is_lead")
  status          EntityStatus @default(active)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  appliesToType OrgUnitType?  @relation(fields: [appliesToTypeId], references: [id], onDelete: Restrict)
  appointments  Appointment[]

  @@index([appliesToTypeId])
  @@index([status])
  @@map("position")
}

model Appointment {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  academicYearId String        @map("academic_year_id") @db.Uuid
  orgUnitId      String        @map("org_unit_id") @db.Uuid
  orgUnitTypeId  String?       @map("org_unit_type_id") @db.Uuid
  positionId     String        @map("position_id") @db.Uuid
  personId       String        @map("person_id") @db.Uuid
  titleOverride  String?       @map("title_override")
  // Denormalized "this appointment's position is a singleton (max_holders=1)".
  // Maintained by the appointment_type_guard trigger from position.max_holders;
  // backs the concurrency-safe singleton partial-unique (DL-021).
  isSingleton    Boolean       @default(false) @map("is_singleton")
  status         ContentStatus @default(draft)
  publishedAt    DateTime?     @map("published_at") @db.Timestamptz
  sortOrder      Int           @default(0) @map("sort_order")
  startDate      DateTime?     @map("start_date") @db.Date
  endDate        DateTime?     @map("end_date") @db.Date
  archivedAt     DateTime?     @map("archived_at") @db.Timestamptz
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  createdById    String?       @map("created_by") @db.Uuid
  updatedById    String?       @map("updated_by") @db.Uuid

  academicYear AcademicYear @relation("AppointmentYear", fields: [academicYearId], references: [id], onDelete: Restrict)
  orgUnit      OrgUnit      @relation("AppointmentOrgUnit", fields: [orgUnitId, academicYearId], references: [id, academicYearId], onDelete: Restrict)
  orgUnitType  OrgUnitType? @relation(fields: [orgUnitTypeId], references: [id], onDelete: Restrict)
  position     Position     @relation(fields: [positionId], references: [id], onDelete: Restrict)
  person       Person       @relation(fields: [personId], references: [id], onDelete: Restrict)
  createdBy    User?        @relation("AppointmentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?        @relation("AppointmentUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([orgUnitId, academicYearId, status])
  @@index([personId, academicYearId])
  @@index([positionId])
  @@index([academicYearId])
  @@map("appointment")
}

// ──────────────────────────────────────────────────────────────────────────
// CONTENT SPINE (header + immutable revision + per-type payloads)
// ──────────────────────────────────────────────────────────────────────────

model ContentTypeDef {
  contentType     String       @id @map("content_type")
  label           String
  isYearScoped    Boolean      @default(true) @map("is_year_scoped")
  supportsPublish Boolean      @default(true) @map("supports_publish")
  isOrgBound      Boolean      @default(false) @map("is_org_bound")
  payloadTable    String       @map("payload_table")
  status          EntityStatus @default(active)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  contentItems ContentItem[]

  @@index([status])
  @@map("content_type_def")
}

model ContentItem {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contentType         String        @map("content_type")
  academicYearId      String?       @map("academic_year_id") @db.Uuid
  orgUnitId           String?       @map("org_unit_id") @db.Uuid
  lineageKey          String        @map("lineage_key") @db.Uuid // document lineage (plain uuid, not an org_unit_lineage FK)
  slug                String?
  status              ContentStatus @default(draft)
  publishedRevisionId String?       @map("published_revision_id") @db.Uuid // PLAIN cache column, NOT an FK (see DL-005)
  draftRevisionId     String?       @map("draft_revision_id") @db.Uuid // PLAIN cache column, NOT an FK (see DL-005)
  publishedAt         DateTime?     @map("published_at") @db.Timestamptz
  publishedById       String?       @map("published_by") @db.Uuid
  pinned              Boolean       @default(false)
  archivedAt          DateTime?     @map("archived_at") @db.Timestamptz
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  createdById         String?       @map("created_by") @db.Uuid
  updatedById         String?       @map("updated_by") @db.Uuid

  contentTypeDef ContentTypeDef @relation(fields: [contentType], references: [contentType], onDelete: Restrict)
  academicYear   AcademicYear?  @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
