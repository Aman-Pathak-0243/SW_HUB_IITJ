{
  "name": "iit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e .env.local -- prisma migrate deploy",
    "db:migrate:dev": "dotenv -e .env.local -- prisma migrate dev",
    "db:seed": "dotenv -e .env.local -- node prisma/seed.mjs",
    "db:import:org": "dotenv -e .env.local -- node scripts/import-org.mjs",
    "db:import:events": "dotenv -e .env.local -- node scripts/import-events.mjs",
    "db:reset": "dotenv -e .env.local -- prisma migrate reset",
    "db:studio": "dotenv -e .env.local -- prisma studio"
  },
  "prisma": {
    "seed": "dotenv -e .env.local -- node prisma/seed.mjs"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^6.19.3",
    "lucide": "^0.552.0",
    "lucide-react": "^0.552.0",
    "mongoose": "^8.19.2",
    "motion": "^12.23.24",
    "next": "^16.2.9",
    "next-auth": "^4.24.14",
    "pdfjs-dist": "^6.0.227",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.5.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "24.9.1",
    "@types/react": "19.2.2",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "vitest": "^3.2.6"
  }
}
